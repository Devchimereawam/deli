DEBUG=True
SECRET_KEY=replace-with-a-long-random-django-secret

# Public backend URL.
# Local WhatsApp/Nomba testing usually uses your current ngrok HTTPS URL.
PUBLIC_BASE_URL=https://your-domain-or-ngrok-url
NGROK_URL=https://your-domain-or-ngrok-url

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=replace-with-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-meta-phone-number-id
WHATSAPP_VERIFY_TOKEN=replace-with-your-webhook-verify-token
WHATSAPP_PUBLIC_NUMBER=2347089823013
DELI_DASH_WHATSAPP_NUMBER=234XXXXXXXXXX
WHATSAPP_STALE_MESSAGE_MINUTES=20
DELI_CUSTOMER_SERVICE_FEE=200
DELI_MAINTENANCE_FEE=100
DELI_RESTAURANT_PAYOUT_FEE=200
DELI_RIDER_PAYOUT_FEE=200

# Nomba
# Keep /v1 in this value. The code also protects against accidentally omitting it.
NOMBA_BASE_URL=https://sandbox.nomba.com/v1
NOMBA_ACCOUNT_ID=f666ef9b-888e-4799-85ce-acb505b28023
NOMBA_PARENT_ACCOUNT_ID=f666ef9b-888e-4799-85ce-acb505b28023
NOMBA_SUB_ACCOUNT_ID=replace-with-your-team-sub-account-id
NOMBA_CLIENT_ID=replace-with-your-test-or-live-client-id
NOMBA_CLIENT_SECRET=replace-with-your-test-or-live-private-key
NOMBA_WEBHOOK_SECRET=NombaHackathon2026
NOMBA_CALLBACK_URL=https://your-domain-or-ngrok-url/api/v1/payments/return/

# Optional. Use Card during sandbox checkout testing for the cleanest success path.
# Leave blank in production if you want Nomba to show every enabled payment method.
NOMBA_ALLOWED_PAYMENT_METHODS=Card
